@model Event_BIT240004

@{
    ViewData["Title"] = "Xóa sự kiện";
}

<h1>Xóa sự kiện</h1>

<h3 class="text-danger">Bạn có chắc chắn muốn xóa sự kiện này?</h3>

<div asp-validation-summary="All" class="text-danger"></div>

<div>
    <h4>@Model.Name</h4>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">Mô tả</dt>
        <dd class="col-sm-10">@Model.Description</dd>
        <dt class="col-sm-2">Giá</dt>
        <dd class="col-sm-10">@Model.Price.ToString("N0")</dd>
        <dt class="col-sm-2">Bắt đầu</dt>
        <dd class="col-sm-10">@Model.StartDate.ToString("dd/MM/yyyy HH:mm")</dd>
        <dt class="col-sm-2">Kết thúc</dt>
        <dd class="col-sm-10">@Model.EndDate.ToString("dd/MM/yyyy HH:mm")</dd>
    </dl>
    
    <form asp-action="Delete">
        <input type="hidden" asp-for="Id" />
        <input type="submit" value="Xóa" class="btn btn-danger" /> |
        <a asp-action="Index" class="btn btn-secondary">Quay lại danh sách</a>
    </form>
</div>
