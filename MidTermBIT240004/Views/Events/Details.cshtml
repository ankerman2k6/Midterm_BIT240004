@model Event_BIT240004

@{
    ViewData["Title"] = "Chi tiết sự kiện";
}

<h1>Chi tiết sự kiện</h1>

<div>
    <h4>@Model.Name</h4>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">Mô tả</dt>
        <dd class="col-sm-10">@Model.Description</dd>
        <dt class="col-sm-2">Giá</dt>
        <dd class="col-sm-10">@Model.Price.ToString("N0")</dd>
        <dt class="col-sm-2">Bắt đầu</dt>
        <dd class="col-sm-10">@Model.StartDate.ToString("dd/MM/yyyy HH:mm")</dd>
        <dt class="col-sm-2">Kết thúc</dt>
        <dd class="col-sm-10">@Model.EndDate.ToString("dd/MM/yyyy HH:mm")</dd>
        <dt class="col-sm-2">Địa điểm</dt>
        <dd class="col-sm-10">@Model.Location</dd>
        <dt class="col-sm-2">Loại sự kiện</dt>
        <dd class="col-sm-10">@Model.EventCategory?.Name</dd>
    </dl>
</div>

<h3>Ảnh sự kiện</h3>
<p>
    <a asp-controller="EventImages" asp-action="Create" asp-route-eventId="@Model.Id" class="btn btn-sm btn-primary">Thêm ảnh</a>
</p>

@if (Model.EventImages == null || !Model.EventImages.Any())
{
    <p class="text-danger">Sự kiện chưa có ảnh.</p>
}
else
{
    <div class="row">
        @foreach (var img in Model.EventImages)
        {
            <div class="col-md-3 mb-3">
                <div class="card h-100">
                    <img src="@img.ImageUrl" class="card-img-top" alt="Ảnh sự kiện" style="height: 200px; object-fit: cover;">
                    <div class="card-body">
                        @if (img.IsThumbnail)
                        {
                            <span class="badge bg-success">Ảnh đại diện</span>
                        }
                        else
                        {
                            <form asp-controller="EventImages" asp-action="SetThumbnail" method="post" style="display:inline;">
                                <input type="hidden" name="id" value="@img.Id" />
                                <button type="submit" class="btn btn-sm btn-outline-primary">Đặt làm ảnh đại diện</button>
                            </form>
                        }
                        <a asp-controller="EventImages" asp-action="Delete" asp-route-id="@img.Id" class="btn btn-sm btn-danger float-end">Xóa</a>
                    </div>
                </div>
            </div>
        }
    </div>
}

<div>
    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">Sửa</a>
    <a asp-action="Index" class="btn btn-secondary">Quay lại danh sách</a>
</div>
