@model EventImage_BIT240004

@{
    ViewData["Title"] = "Xóa ảnh";
}

<h1>Xóa ảnh</h1>

<h3 class="text-danger">Bạn có chắc chắn muốn xóa ảnh này?</h3>
<div>
    <hr />
    <img src="@Model.ImageUrl" alt="Ảnh sự kiện" style="max-width: 300px;" />
    
    <form asp-action="Delete" class="mt-4">
        <input type="hidden" asp-for="Id" />
        <input type="submit" value="Xóa" class="btn btn-danger" /> |
        <a asp-controller="Events" asp-action="Details" asp-route-id="@Model.EventId" class="btn btn-secondary">Quay lại chi tiết sự kiện</a>
    </form>
</div>
